PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret
FRONTEND_URL=http://localhost:5173

# Local development uses MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/luxestep
MONGO_DB=luxestep

# Production uses PostgreSQL or Supabase
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/luxestep
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/luxestep
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:5432/luxestep

# Optional Cloudinary values if you want to manage images via Cloudinary URLs
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
